# === 2. Python 环境与虚拟环境 (关键隔离) ===
.venv*/
venv/
ENV/
ENV*/
bin/
include/
lib/
share/
pyvenv.cfg
*.manifest
*.spec

# === 3. Python 缓存与临时文件 ===
__pycache__/
*.py[cod]
*$py.class
*.tmp
*.bak
*.log
/logs/

# === 4. Django 框架产物 ===
db.sqlite3
db.sqlite3-journal
db.sqlite3-shm
db.sqlite3-wal
/static/collected/
/staticfiles/
/media/
